{"legislative_session": "2025_26", "identifier": "HB 1537", "title": "Bibb County; ad valorem tax for educational purposes; provide a homestead exemption", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to provide a homestead exemption from Bibb County school district ad valorem taxes for educational purposes in the amount of $17,000.00 of the assessed value of the homestead for residents of that school district who are between the ages of 65 and 74; to provide a homestead exemption from Bibb County school district ad valorem taxes for educational purposes in the amount of $32,000.00 of the assessed value of the homestead for residents of that school district who are between the ages of 75 and 84; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1537"}], "actions": [{"description": "House Hopper", "date": "2026-03-10", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}, {"description": "House Committee Favorably Reported", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Intragovernmental Coordination", "entity_type": "organization", "organization_id": null}]}, {"description": "House Third Readers", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-3"]