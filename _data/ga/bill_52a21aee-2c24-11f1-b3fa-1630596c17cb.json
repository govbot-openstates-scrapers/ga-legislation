{"legislative_session": "2025_26", "identifier": "HB 1486", "title": "Education; term \"education record\"; revise definitions", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["EDUCATION"], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend Title 20 of the Official Code of Georgia Annotated, relating to education, so as to revise definitions of the term \"education record\"; to include additional cross-references relative to access to student education records by parents and legal custodians; to repeal a specific time limitation upon a parent or legal custodian's right to request education records; to replace certain terms used in such title with \"school business day\"; to provide for definitions; to provide for an effective date; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1486"}], "actions": [{"description": "House Hopper", "date": "2026-03-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-04", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}], "sponsorships": [{"name": "Holt Persinger", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Holt Persinger\"}", "organization_id": null}, {"name": "Beth Camp", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Beth Camp\"}", "organization_id": null}, {"name": "Chris Erwin", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~