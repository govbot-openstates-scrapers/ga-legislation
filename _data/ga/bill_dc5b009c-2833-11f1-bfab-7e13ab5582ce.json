{"legislative_session": "2025_26", "identifier": "HB 1581", "title": "Fayetteville, City of; ad valorem tax for municipal purposes; provide homestead exemption", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to provide a homestead exemption from City of Fayetteville ad valorem taxes for municipal purposes in a floating proportional amount based upon any increased property tax collections that exceed the value of property taxes collected in tax year 2025; to provide for definitions; to specify the terms and conditions of the exemption and the procedures relating thereto; to provide for applicability; to provide for compliance with constitutional requirements; to provide for a referendum, effective dates, automatic repeal, mandatory execution of election, and judicial remedies regarding failure to comply; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1581"}], "actions": [{"description": "House Hopper", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-20", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}], "sponsorships": [{"name": "Josh Bonner", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Josh Bonner\"}", "organization_id": null}, {"name": "Karen Mathiak", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Karen Mathiak\"}", "organization_i