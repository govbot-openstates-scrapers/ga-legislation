{"legislative_session": "2025_26", "identifier": "HB 1552", "title": "Bremen, City of; school district ad valorem tax; provide homestead exemption", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to provide a homestead exemption from City of Bremen independent school district ad valorem taxes for educational purposes in the amount of $90,000.00 of the assessed value of the homestead for residents of that school district who are 65 years of age or older and who have been residents and property taxpayers of the school district for at least five consecutive years; to repeal the exemption granted in an Act approved May 13, 2008 (Ga. L. 2008, p. 4065); to provide for compliance with constitutional requirements; to provide for a referendum, effective dates, automatic repeal, mandatory execution of election, and judicial remedies regarding failure to comply; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1552"}], "actions": [{"description": "House Hopper", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}, {"description": "House Committee Favorably Reported", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Intragovernmental Coordination", "entity_type": "organization", "organization_id":