{"legislative_session": "2025_26", "identifier": "SB 498", "title": "Georgia Charter School Facilities Authority; establish", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["EDUCATION"], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend Article 31B of Chapter 2 of Title 20 of the O.C.G.A., relating to charter school capital finance, so as to establish the Georgia Charter School Facilities Authority for the purpose of enabling charter schools to obtain revolving loan funds and other public financing assistance for purposes of constructing, renovating, and rehabilitating educational facilities for such schools;to amend Article 2 of Chapter 17 of Title 50 of the O.C.G.A., the \"Georgia State Financing and Investment Commission Act,\" so as to provide for the issuance of general obligation bonds by the Georgia State Financing and Investment Commission to provide for educational facilities for charter schools; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-sb498"}], "actions": [{"description": "Senate Hopper", "date": "2026-02-11", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "Senate Read and Referred", "date": "2026-02-12", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Finance", "entity_type": "organization", "organization_id": null}]}, {"description": "Senate Committee Favorably Reported  By Substitute", "date": "2026-02-26", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Finance", "entity_type": "organization", "organization_id": null}]}, {"description": "Senate Read Second Time", "date": "2026-03-03", "organi