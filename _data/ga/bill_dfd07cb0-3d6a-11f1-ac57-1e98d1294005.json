{"legislative_session": "2025_26", "identifier": "HB 372", "title": "Teachers Retirement System; certain beneficiaries hired to work in certain areas; provisions", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["EDUCATION", "RETIREMENT AND PENSIONS"], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend Article 7 of Chapter 3 of Title 47 of the Official Code of Georgia Annotated, relating to retirement allowances, disability benefits, and spouses' benefits, so as to remove the requirement that certain subject areas be designated as an area of highest need for certain beneficiaries of the Teachers Retirement System of Georgia to be hired to work in such areas; to provide for the extension of provisions to 2030; to provide for areas of highest need to be determined for a public school system rather than a RESA; to provide for related matters; to provide conditions for an effective date and automatic repeal; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb372"}], "actions": [{"description": "House Hopper", "date": "2025-02-10", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2025-02-11", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2025-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}, {"description": "House Committee Favorably Reported By Substitute", "date": "2026-02-12", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Retirement", "entity_type": "organization", "organization_id": null}]}, {"description": "Hous