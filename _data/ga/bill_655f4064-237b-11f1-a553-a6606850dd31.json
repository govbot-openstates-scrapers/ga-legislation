{"legislative_session": "2025_26", "identifier": "HB 1580", "title": "Henry County Airport Authority; current operative provisions; repeal and replace", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend an Act creating the Henry County Airport Authority, approved May 3, 2023 (Ga. L. 2023, p. 4389), as amended, so as to repeal and replace all current operative provisions related to such authority; to authorize the issuance of refunding bonds, securities or other obligations; to provide that such bonds, securities or other obligations be validated as authorized by the Article 3 of Chapter 82 of Title 36 of the O.C.G.A, the \"Revenue Bond Law\" as now or hereafter amended; to authorize the Authority to exercise the power of condemnation; to provide for all matters relative thereto; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1580"}], "actions": [{"description": "House Hopper", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}], "sponsorships": [{"name": "El-Mahdi Holly", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"El-Mahdi Holly\"}", "organization_id": null}, {"name": "Demetrius Douglas", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Demetrius Douglas\"}", "organization_id": null}, {"name": "Mary Ann Santos", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Mary Ann Santos\"}", "organization_id": null}, {"name": "Regina Lewis-Ward", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Regina Lewis-Ward\"}", "organization_id":