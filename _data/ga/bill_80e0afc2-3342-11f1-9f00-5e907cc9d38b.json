{"legislative_session": "2025_26", "identifier": "SB 629", "title": "Town of Braswell; transfer of duties and obligations to Paulding and Polk counties; provide", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to repeal an Act incorporating the town of Braswell, approved December 13, 1895, (Ga. L. 1895, p. 142), as amended; to provide for transfer of duties and obligations to Paulding and Polk counties; to provide for transfer of all legal rights, privileges, and assets to Paulding and Polk counties; to establish special tax and service districts for outstanding bonded indebtedness and other obligations; to provide for future proceeds of special and regular local option sales taxes; to provide for the designation of the Community of Braswell; to provide for related matters; to provide an effective date; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-sb629"}], "actions": [{"description": "Senate Hopper", "date": "2026-03-20", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "Senate Read and Referred", "date": "2026-03-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "State and Local Governmental Operations", "entity_type": "organization", "organization_id": null}]}, {"description": "Senate Committee Favorably Reported  By Substitute", "date": "2026-03-31", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "State and Local Governmental Operations", "entity_type": "organization", "organization_id": null}]}, {"description": "Senate Passed/Adopted By Substitute", "date": "2026-03-31", "organization_id": "~{\