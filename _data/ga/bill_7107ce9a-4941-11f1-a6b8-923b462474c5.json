{"legislative_session": "2025_26", "identifier": "HB 1602", "title": "Gainesville, City of; school district ad valorem tax; provide homestead exemption", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to provide a homestead exemption from City of Gainesville independent school district ad valorem taxes for educational purposes in the amount of $10,000.00 of the assessed value of the homestead for residents of that school district; to provide for definitions; to specify the terms and conditions of the exemption and the procedures relating thereto; to provide for applicability; to provide for compliance with constitutional requirements; to provide for a referendum, effective dates, automatic repeal, mandatory execution of election, and judicial remedies regarding failure to comply; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1602"}], "actions": [{"description": "House Hopper", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}, {"description": "House Committee Favorably Reported", "date": "2026-03-27", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Intragovernmental Coordination", "entity_type": "organization", "organization_id": null}]}, {"description": "House Third Readers", "date": "2026-03-27", "o