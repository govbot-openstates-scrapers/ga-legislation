{"legislative_session": "2025_26", "identifier": "SB 631", "title": "\"Veterans Mental Health Innovations Act\"; enact", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": ["HEALTH"], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend Article 1 of Chapter 2A Title 31 of the Official Code of Georgia Annotated, relating to general provisions of the Department of Public Health, so as to authorize the department to award grants to eligible entities to conduct clinical trials approved by the United States Food and Drug Administration as a part of a multistate consortium using ibogaine as an investigational new drug for the treatment of opioid use disorder, co-occurring substance use disorder, and any other neurological or mental health conditions as related to veterans for which ibogaine demonstrates efficacy; to provide for a short title; to provide for an effective date; to provide for contingencies; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-sb631"}], "actions": [{"description": "Senate Hopper", "date": "2026-03-23", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "Senate Read and Referred", "date": "2026-03-25", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "Health and Human Services", "entity_type": "organization", "organization_id": null}]}], "sponsorships": [{"name": "Sonya Halpern", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Sonya Halpern\"}", "organization_id": null}, {"name": "Tonya Anderson", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Tonya Anderson\"}", "organization_id": null}, {"name": "Kenya Wicks", "classificatio