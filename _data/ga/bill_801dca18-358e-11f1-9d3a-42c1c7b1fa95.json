{"legislative_session": "2025_26", "identifier": "HB 1555", "title": "Fort Valley, City of; deannex certain territory", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend an Act providing a new charter for the City of Fort Valley, approved August 22, 1907 (Ga. L. 1907, p. 651), as amended, so as to deannex certain territory from the city limits; to provide that the city shall be obligated to transfer title in any real or personal property related to the operation of the utility system upon the request of the utility commission; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1555"}], "actions": [{"description": "House Hopper", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}, {"description": "House Committee Favorably Reported", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Intragovernmental Coordination", "entity_type": "organization", "organization_id": null}]}, {"description": "House Third Readers", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-3"], "related_entities": []}, {"description": "House Passed/Adopted", "date": "2026-03-23", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["pass