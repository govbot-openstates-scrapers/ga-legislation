{"legislative_session": "2025_26", "identifier": "HB 1562", "title": "Pike County; ad valorem tax; increase amount of homestead exemption for residents who are totally disabled", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend an Act providing a homestead exemption from all Pike County ad valorem taxes for county purposes for certain residents of that county who are totally disabled, approved May 13, 2002 (Ga. L. 2002, p. 5732), so as to increase the amount of the homestead exemption for residents of Pike County who are totally disabled; to provide for increased amounts of homestead exemptions for certain residents who have resided in the county for a certain amount of time; to provide for a referendum; to provide for an effective date and applicability; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1562"}], "actions": [{"description": "House Hopper", "date": "2026-03-16", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-18", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-19", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}, {"description": "House Committee Favorably Reported By Substitute", "date": "2026-03-27", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Intragovernmental Coordination", "entity_type": "organization", "organization_id": null}]}, {"description": "House Third Readers", "date": "2026-03-27", "organ