{"legislative_session": "2025_26", "identifier": "HB 1505", "title": "Quality Basic Education Act; prescribed course of study in sex education and human immunodeficiency virus (HIV) prevention instruction is age appropriate and medically accurate; provide", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["EDUCATION", "HEALTH"], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend Part 2 of Article 6 of Chapter 2 of Title 20 of the Official Code of Georgia Annotated, relating to competencies and core curriculum under the \"Quality Basic Education Act,\" so as to provide that the prescribed course of study in sex education and human immunodeficiency virus (HIV) prevention instruction is age appropriate and medically accurate and promotes sexual abstinence; to include the subject of personal responsibility in such course of study; to provide for implementation; to provide for a definition; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "House Hopper", "date": "2026-03-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-03-04", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-03-06", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}], "sponsorships": [{"name": "Will Wade", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Will Wade\"}", "organization_id": null}, {"name": "Sandy Donatucci", "classification": "primary", "entity_type": "person", "primary": true, "person_id": "~{\"name\": \"Sandy Donatucci\"}", "organization_id": null