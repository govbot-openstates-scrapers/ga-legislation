{"legislative_session": "2025_26", "identifier": "SB 612", "title": "City of Cochran Public Facilities Authority; create", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to create the City of Cochran Public Facilities Authority; to provide that the authority is a body corporate and politic and an instrumentality of the State of Georgia; to authorize the authority to acquire, construct, equip, maintain, and operate certain projects, including buildings and facilities for use by the City of Cochran for its governmental, proprietary, and administrative functions; to provide that certain moneys are trust funds; to provide that this Act shall be liberally construed; to define the scope of the authority's operation; to provide for disposition of property upon dissolution of the authority; to provide for severability; to provide for a short title; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-sb612"}], "actions": [{"description": "Senate Hopper", "date": "2026-03-02", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["introduction"], "related_entities": []}, {"description": "Senate Read and Referred", "date": "2026-03-03", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["referral-committee"], "related_entities": [{"name": "State and Local Governmental Operations", "entity_type": "organization", "organization_id": null}]}, {"description": "Senate Committee Favorably Reported", "date": "2026-03-06", "organization_id": "~{\"classification\": \"upper\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "State and Local Governmental Operations", "entity_type": "organization", "organization_id": null}]}, {"description": "Senate Passed/Adopted", "dat