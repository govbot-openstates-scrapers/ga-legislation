{"legislative_session": "2025_26", "identifier": "HB 1434", "title": "Aviation; air facilities; identification of airport affected areas; provide", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["AVIATION"], "abstracts": [{"note": "description", "abstract": "A BILL to be entitled an Act to amend Chapter 3 of Title 6 of the Official Code of Georgia Annotated, relating to powers of local governments as to air facilities, so as to provide for the identification of airport affected areas; to provide for public notice and public hearing; to require the adoption, administration, and enforcement of regulations relative to the use of land in airport affected areas; to provide for standards for adoption of such regulations; to provide for consultation with the Department of Transportation; to provide for the adoption of local methods of enforcing regulations relative to airport area affected areas; to provide for a method for requesting variances; to provide for penalties; to provide for definitions; to provide for related matters; to repeal conflicting laws; and for other purposes."}], "other_titles": [], "other_identifiers": [{"identifier": "ocd-bill-ga-2025_26-hb1434"}], "actions": [{"description": "House Hopper", "date": "2026-02-24", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "House First Readers", "date": "2026-02-25", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-1"], "related_entities": []}, {"description": "House Second Readers", "date": "2026-02-26", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["reading-2"], "related_entities": []}, {"description": "House Committee Favorably Reported By Substitute", "date": "2026-03-03", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage-favorable"], "related_entities": [{"name": "Transpor